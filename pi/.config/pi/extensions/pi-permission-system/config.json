{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-packages/main/packages/pi-permission-system/schemas/permissions.schema.json",
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      ".git/*": "deny",
      "**/.git/*": "deny",
      ".ssh/*": "deny",
      "~/.ssh/*": "deny"
    },
    "read": "allow",
    "external_directory": {
      "*": "ask",
      "~/Documents/Work/*": "allow",
      "~/Documents/Personal/*": "allow"
    },
    "bash": {
      "*": "ask",
      "rm": "ask",
      "rm *": "ask",
      "mv": "ask",
      "mv *": "ask",
      "sh": "ask",
      "sh *": "ask",
      "curl": "ask",
      "curl *": "ask",
      "wget": "ask",
      "wget *": "ask",
      "jq *": "allow",
      "ag *": "allow",
      "rg *": "allow",
      "echo *": "allow",
      "tmux display-message *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "pwd *": "allow",
      "exa *": "allow",
      "eza *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "awk *": "allow",
      "gh *": "ask",
      "gh api *": "ask",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr checks *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh repo view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh search prs *": "allow",
      "gh pr status *": "allow",
      "gh pr create *": "deny",
      "git *": "ask",
      "git commit *": "ask",
      "git config *": "ask",
      "git diff *": "allow",
      "git push *": "deny",
      "git log *": "allow",
      "git rebase *": "ask",
      "git rebase --continue": "allow",
      "git remote *": "ask",
      "git show *": "allow",
      "git status *": "allow",
      "npm run test *": "allow",
      "npm test *": "allow",
      "npm run lint *": "allow",
      "npm run type-check *": "allow",
      "npm run lint -- --fix *": "allow",
      "pnpm vitest *": "allow",
      "pnpm test *": "allow",
      "pnpm test:ci *": "allow",
      "pnpm lint *": "allow",
      "pnpm lint:files *": "allow",
      "pnpm type-check *": "allow",
      "pnpm lint -- --fix *": "allow",
      "node -e *": "deny",
      "python -c *": "deny"
    },
    "mcp": {
      "*": "ask"
    }
  }
}
