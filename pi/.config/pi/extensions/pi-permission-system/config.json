// vim: set filetype=jsonc:
{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-packages/main/packages/pi-permission-system/schemas/permissions.schema.json",
  "piInfrastructureReadPaths": [
    "~/.dot/pi/.config/pi/npm/*",
    "~/.dot/pi/.config/pi/git/*",
    "~/.bun/install/global/node_modules/@earendil-works/pi-coding-agent/**"
  ],
  "debugLog": true,
  "permissionReviewLog": true,
  "yoloMode": false,
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "apply_patch": "allow",
    "webfetch": "ask",
    "rich-webfetch": "ask",
    "subagent": "allow",
    "get_subagent_result": "allow",
    "memory": "allow",
    "memory *": "allow",
    "memory_*": "allow",
    "colgrep": "allow",
    "skill": {
      "*": "ask",
      "colgrep": "allow",
      "create-skill": "allow",
      "pr-review": "allow"
    },
    "bash": {
      //////////////////////
      // keep on the top
      //////////////////////
      "*": "ask",
      "curl *": "ask",
      "curl": "ask",
      "mv *": "ask",
      "mv": "ask",
      "rm *": "ask",
      "rm": "ask",
      "sh *": "ask",
      "sh": "ask",
      "wget *": "ask",
      "wget": "ask",
      "awk": "ask",
      "awk *": "ask",
      "awk *system(*": "deny",
      "awk *\"*|*getline*": "deny",
      //////////////////////
      // white listed
      //////////////////////
      "ag *": "allow",
      "basename *": "allow",
      "basedpyright *": "ask",
      "basedpyright --help": "allow",
      "basedpyright --level error *": "allow",
      "basedpyright --verbose *": "allow",
      "basedpyright -p *": "allow",
      "basedpyright *--createstub*": "ask",
      "basedpyright *--writebaseline*": "ask",
      "basedpyright *--baselinemode=auto*": "ask",
      "basedpyright *--gitlabcodequality*": "ask",
      "cat *": "allow",
      "colgrep": "allow",
      "colgrep *": "allow",
      "command *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "echo *": "allow",
      "exa *": "allow",
      "eza *": "allow",
      "file *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ln *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "nl": "allow",
      "nl *": "allow",
      "pi config *": "allow",
      "printf *": "allow",
      "pwd *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "stylua": "allow",
      "stylua *": "allow",
      "tail *": "allow",
      "timeout *": "allow",
      "tmux display-message *": "allow",
      "touch *": "allow",
      "tree *": "allow",
      "type *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",
      /////////
      // find
      /////////
      "find": "allow",
      "find *": "allow",
      "find * -delete": "ask",
      "find * -exec *": "deny",
      "find * -execdir *": "deny",
      "find * -ok *": "deny",
      "find * -okdir *": "deny",
      /////////
      // gh
      /////////
      "gh": "ask",
      "gh *": "ask",
      "gh api": "ask",
      "gh api *": "ask",
      "gh issue list": "allow",
      "gh issue list *": "allow",
      "gh issue view": "allow",
      "gh issue view *": "allow",
      "gh pr checks": "allow",
      "gh pr checks *": "allow",
      "gh pr diff": "allow",
      "gh pr diff *": "allow",
      "gh pr list": "allow",
      "gh pr list *": "allow",
      "gh pr view": "allow",
      "gh pr view *": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",
      "gh run list": "allow",
      "gh run list *": "allow",
      "gh run view": "allow",
      "gh run view *": "allow",
      "gh search prs": "allow",
      "gh search prs *": "allow",
      "gh pr status": "allow",
      "gh pr status *": "allow",
      "gh pr create *": "deny",
      /////////
      // git
      /////////
      "git": "ask",
      "git *": "ask",
      "git bisect": "allow",
      "git bisect *": "allow",
      "git commit": "ask",
      "git commit *": "ask",
      "git config": "ask",
      "git config *": "ask",
      "git add": "allow",
      "git add *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git push": "deny",
      "git push *": "deny",
      "git rebase": "deny",
      "git rebase *": "deny",
      "git rebase --continue": "ask",
      "git remote": "allow",
      "git remote *": "ask",
      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      /////////
      // npm
      /////////
      "npm run test": "allow",
      "npm run test *": "allow",
      "npm test": "allow",
      "npm test *": "allow",
      "npm run lint": "allow",
      "npm run lint *": "allow",
      "npm run type-check": "allow",
      "npm run type-check *": "allow",
      "npm run lint -- --fix": "allow",
      "npm run lint -- --fix *": "allow",
      /////////
      // pnpm
      /////////
      "pnpm vitest": "allow",
      "pnpm vitest *": "allow",
      "pnpm test": "allow",
      "pnpm test *": "allow",
      "pnpm test:ci": "allow",
      "pnpm test:ci *": "allow",
      "pnpm lint": "allow",
      "pnpm lint *": "allow",
      "pnpm lint:files": "allow",
      "pnpm lint:files *": "allow",
      "pnpm type-check": "allow",
      "pnpm type-check *": "allow",
      "pnpm lint -- --fix": "allow",
      "pnpm lint -- --fix *": "allow",
      "pnpm --version*": "allow",
      /////////
      // node
      /////////
      "node --check *": "allow",
      "node -e *": "deny",
      ////////////////
      // Black listed at the end, last win
      ////////////////
      "python -c *": "deny"
    },
    "path": {
      // green
      "*": "allow",
      "*.env.example": "allow",
      // red
      "*.env": "deny",
      "*.env.*": "deny",
      ".git/*": "deny",
      "**/.git/*": "deny",
      ".ssh/*": "deny",
      "~/.ssh/*": "deny",
      "*/.config/pi/get-api-key.sh": "deny",
      "*auth.json": "deny"
    },
    "external_directory": {
      //////////////////////
      // keep on the top
      //////////////////////
      "*": "ask",
      //////////////////////
      // white listed
      //////////////////////
      "~/Documents/Work/*": "allow",
      "~/Documents/Personal/*": "allow",
      "~/.dot/pi/.config/pi/tmp/*": "allow"
    }
  }
}
