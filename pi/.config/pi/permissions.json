    { "pattern": "**/.git/**", "action": "deny" },
    { "pattern": ".git/**", "action": "deny" },
    { "pattern": "**/.ssh/**", "action": "deny" },
    { "pattern": ".ssh/**", "action": "deny" },
    { "pattern": "~/Documents/Work/**", "action": "allow" },
    { "pattern": "~/Documents/Personal/**", "action": "allow" }
  ],
  "write": [
    { "pattern": "*", "action": "allow" },
