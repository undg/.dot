# vim: set ft=sh :
case "${hook_name:-}" in
commit-msg)
	msg_file=$1
	if [ -n "$msg_file" ] && [ -f "$msg_file" ]; then
		if [ -x "$HOME/bin/git-commit-msg-prefix-with-ticket" ]; then
			"$HOME/bin/git-commit-msg-prefix-with-ticket" "$msg_file"
		else
			echo "warning: git-commit-msg-prefix-with-ticket not found, skipping auto-prefix" >&2
		fi
	fi
	;;
esac

case "$(git rev-parse --show-toplevel 2>/dev/null):${hook_name:-}" in
"$HOME/Code/pgm-fe:commit-msg")
	echo '-----=====bypass commit-msg lint=====-----'
	exit 0
	;;
esac
